# RoseCloud 生产环境变量模板
# ============================================================
# 用法：复制为 .env（已被 .gitignore 忽略，绝不提交），填入你自己生成的强值。
#   cp .env.example .env
#   # 编辑 .env，替换所有 <...> 占位符为唯一强值
#   docker compose --profile microservice up -d
#
# 本地开发可直接 `docker compose up`（docker-compose.yml 内已内置弱默认值便于起站），
# 无需 .env。本文件用于生产部署时必须覆盖下列密钥。
# 生成示例：
#   openssl rand -base64 32        # Nacos token / JWT secret
#   openssl rand -hex 16           # Nacos identity
#   openssl rand -base64 18 | tr -dc 'A-Za-z0-9' | head -c24   # 各密码

# ---- 数据库 ----
MYSQL_USER=rosecloud
MYSQL_PASSWORD=<生成强值，须与 docker-compose 中 MySQL 容器及 common.yaml 一致>
MYSQL_ROOT_PASSWORD=<生成强值>

# ---- Redis ----
REDIS_PASSWORD=<生成强值，须与 docker-compose 中 redis 容器及 common.yaml 一致>

# ---- RabbitMQ ----
RABBITMQ_USER=rosecloud
RABBITMQ_PASS=<生成强值>

# ---- Nacos 服务端鉴权 ----
NACOS_AUTH_ENABLE=true
# Base64 编码、原始长度 >= 32 字节的强随机值
NACOS_AUTH_TOKEN=<Base64 强随机值>
NACOS_AUTH_IDENTITY_KEY=<强随机值>
NACOS_AUTH_IDENTITY_VALUE=<强随机值>

# ---- Nacos 客户端凭证（覆盖默认 nacos/nacos）----
NACOS_USERNAME=<独立 Nacos 用户名>
NACOS_PASSWORD=<独立强密码>

# ---- xxl-job ----
XXL_JOB_ACCESS_TOKEN=<生成强值>

# ---- JWT ----
# 长随机值；生产应同时把 ROSECLOUD_SECURITY_JWT_ALLOW_DEV_SECRET 设为 false
ROSECLOUD_SECURITY_JWT_SECRET=<长随机值>
ROSECLOUD_SECURITY_JWT_ALLOW_DEV_SECRET=false

# ---- 服务间内部调用密钥 ----
ROSECLOUD_SECURITY_INTERNAL_API_KEY=<生成强值>
