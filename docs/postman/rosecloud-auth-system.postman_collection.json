    {
      "name": "会话",
      "item": [
        {
          "name": "查询在线会话成功",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessTokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/sessions/online"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response is success', function () {",
                  "  pm.expect(json.success).to.equal(true);",
                  "  pm.expect(json.code).to.equal('OK');",
                  "});",
                  "pm.test('records exist', function () {",
                  "  pm.expect(json.data.records).to.be.an('array');",
                  "  pm.expect(json.data.records.length).to.be.greaterThan(0);",
                  "});",
                  "const token = pm.environment.get('accessTokenA');",
                  "const records = json.data.records || [];",
                  "const currentSession = records.find(function (item) { return item.token === token; }) || records[0];",
                  "pm.environment.set('sessionIdA', String(currentSession.id));"
                ]
              }
            }
          ]
        },
