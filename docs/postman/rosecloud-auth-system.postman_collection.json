          "name": "获取可切换租户列表成功",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessTokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/tenants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "tenants"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response is success', function () {",
                  "  pm.expect(json.success).to.equal(true);",
                  "  pm.expect(json.code).to.equal('OK');",
                  "});",
                  "pm.test('selection payload exists', function () {",
                  "  pm.expect(json.data.currentTenantId).to.be.a('string');",
                  "  pm.expect(json.data.switchableTenants).to.be.an('array');",
                  "});",
                  "pm.environment.set('currentTenantId', json.data.currentTenantId);",
                  "const switchable = json.data.switchableTenants || [];",
                  "const other = switchable.find(function (t) { return t.tenantId !== json.data.currentTenantId; }) || switchable[0];",
                  "pm.environment.set('targetTenantId', other ? other.tenantId : '');"
                ]
              }
            }
          ]
        },
