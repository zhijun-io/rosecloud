{
  "info": {
    "_postman_id": "c4df2b1f-2cc7-4c75-9a3c-7d26b7d9d1f0",
    "name": "RoseCloud Auth and User Flows",
    "description": "Login, logout, current user, user query, and token revocation flows for RoseCloud. Run the requests top to bottom the first time so token/session variables can be populated.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "认证",
      "item": [
        {
          "name": "登录成功 - 会话A",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{username}}\",\"password\":\"{{password}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('response is success', function () {",
                  "  pm.expect(json.success).to.equal(true);",
                  "  pm.expect(json.code).to.equal('OK');",
                  "});",
                  "pm.test('tokens are returned', function () {",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.environment.set('accessTokenA', json.data.accessToken);",
                  "pm.environment.set('refreshTokenA', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "登录失败 - 密码错误",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{username}}\",\"password\":\"{{wrongPassword}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response is failure', function () {",
                  "  pm.expect(json.success).to.equal(false);",
                  "  pm.expect(json.code).to.equal('UNAUTHORIZED');",
                  "});",
                  "pm.test('message mentions bad credentials', function () {",
                  "  pm.expect(json.message).to.include('Bad credentials');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "登录失败 - 缺少密码",
          "request": {
