        {
          "name": "查询用户详情成功",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessTokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/system/users/{{currentUserId}}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response is success', function () {",
                  "  pm.expect(json.success).to.equal(true);",
                  "  pm.expect(json.code).to.equal('OK');",
                  "});",
                  "pm.test('user detail payload exists', function () {",
                  "  pm.expect(json.data.id).to.be.ok;",
                  "  pm.expect(json.data.username).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
