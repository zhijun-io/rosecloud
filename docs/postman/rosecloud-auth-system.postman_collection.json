                  "const json = pm.response.json();",
                  "pm.test('response is success', function () {",
                  "  pm.expect(json.success).to.equal(true);",
                  "  pm.expect(json.code).to.equal('OK');",
                  "});",
                  "pm.test('tokens are returned', function () {",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.environment.set('accessTokenA', json.data.accessToken);",
                  "pm.environment.set('refreshTokenA', json.data.refreshToken);"
                ]
              }
            }
