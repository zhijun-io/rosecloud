    {
      "name": "用户",
      "item": [
        {
          "name": "获取当前登录用户成功",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessTokenA}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/system/users/me"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response is success', function () {",
                  "  pm.expect(json.success).to.equal(true);",
                  "  pm.expect(json.code).to.equal('OK');",
                  "});",
                  "pm.test('user payload exists', function () {",
                  "  pm.expect(json.data.user).to.be.an('object');",
                  "  pm.expect(json.data.roles).to.be.an('array');",
                  "});",
                  "pm.environment.set('currentUserId', String(json.data.user.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "获取当前登录用户失败 - 未携带 token",
