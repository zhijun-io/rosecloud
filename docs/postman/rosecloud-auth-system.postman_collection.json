        {
          "name": "切换租户成功",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessTokenA}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/tenants/{{targetTenantId}}/switch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "tenants",
                "{{targetTenantId}}",
                "switch"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const target = pm.environment.get('targetTenantId');",
                  "pm.test('a switchable tenant was found', function () {",
                  "  pm.expect(target, 'no switchable tenant available for this user').to.be.a('string').and.not.empty;",
                  "});",
                  "if (!target) { return; }",
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response is success', function () {",
                  "  pm.expect(json.success).to.equal(true);",
                  "  pm.expect(json.code).to.equal('OK');",
                  "});",
                  "pm.test('new tokens returned', function () {",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "const decode = function (t) {",
                  "  const p = t.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');",
                  "  return JSON.parse(decodeURIComponent(escape(atob(p))));",
                  "};",
                  "const before = decode(pm.environment.get('accessTokenA'));",
                  "const after = decode(json.data.accessToken);",
                  "pm.test('token tenant matches target', function () {",
                  "  pm.expect(after.tenant.toUpperCase()).to.equal(target.toUpperCase());",
                  "});",
                  "pm.test('token was reissued', function () {",
                  "  pm.expect(json.data.accessToken).to.not.equal(pm.environment.get('accessTokenA'));",
                  "});",
                  "pm.environment.set('switchedAccessToken', json.data.accessToken);",
                  "pm.environment.set('switchedRefreshToken', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
